{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "moduleDetection": "force",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["*.ts"],
    "exclude": ["node_modules"]
}